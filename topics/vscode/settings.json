{
  "python.testing.pytestEnabled": true,
  "python.analysis.enablePytestSupport": false,
  "python.testing.unittestArgs": [
    "--noinput"
  ],
  "terminal.external.osxExec": "iTerm.app",
  "git.autofetch": true,
  "files.autoSave": "afterDelay",
  "pylint.importStrategy": "fromEnvironment",
  "window.restoreWindows": "none",
  "javascript.updateImportsOnFileMove.enabled": "always",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "git.openDiffOnClick": false,
  "dotfiles.repository": "jfred/dotfiles",
  "dotfiles.installCommand": "./install.sh git",
  "window.autoDetectColorScheme": true,
  "git.blame.editorDecoration.template": "${hashShort}, ${authorName}",
  "gitlens.autolinks": [
    {
      "prefix": "ENG-",
      "url": "https://linear.app/watchduty/issue/ENG-<num>"
    }
  ],
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4",
  "editor.minimap.enabled": false,
  "explorer.confirmDelete": false,
  "makefile.configureOnOpen": true,
  "settingsSync.ignoredSettings": [],
  "gitlens.advanced.messages": {
    "suppressCommitNotFoundWarning": true
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff"
  },
  "docker.extension.enableComposeLanguageServer": false,
  "telemetry.feedback.enabled": false,
  "telemetry.telemetryLevel": "off",
  "cSpell.userWords": [
    "beresp",
    "broadcastify",
    "burnover",
    "evac",
    "evacs",
    "FASTLY",
    "FASTLYPURGE",
    "filtersep",
    "fireperimeters",
    "posthog",
    "regsuball",
    "sonoma",
    "tileset",
    "tilesets",
    "Uids",
    "Watchduty",
    "weatherstations",
    "workos"
  ],
  "mypy-type-checker.reportingScope": "workspace",
  "mypy-type-checker.importStrategy": "fromEnvironment",
  "mypy-type-checker.showNotifications": "onError",
  "workbench.editor.enablePreview": false,
  "git.blame.editorDecoration.enabled": true,
  "git.blame.statusBarItem.enabled": false,
  "python.defaultInterpreterPath": "/Users/jfred/Code/watchduty/watchduty-backend/.venv",
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  }
}