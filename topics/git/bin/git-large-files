#!/usr/bin/env bash

# Usage: git-large-files [size]
#   size: number with unit (e.g., "5mb", "100kb", "5242880b", "1gb")
#   default: 10mb

# Parse size with unit, defaulting to 10mb
sizeArg="${1:-10mb}"

if [[ "$sizeArg" =~ ^([0-9]+\.?[0-9]*)([kmgb]+)$ ]]; then
  number="${BASH_REMATCH[1]}"
  unit="${BASH_REMATCH[2],,}"  # Convert to lowercase

  case "$unit" in
    b)   maxSize=$(printf "%.0f" "$number") ;;
    kb)  maxSize=$(printf "%.0f" "$(echo "$number * 1024" | bc)") ;;
    mb)  maxSize=$(printf "%.0f" "$(echo "$number * 1024 * 1024" | bc)") ;;
    gb)  maxSize=$(printf "%.0f" "$(echo "$number * 1024 * 1024 * 1024" | bc)") ;;
    *)   echo "Error: Invalid unit '$unit'. Use b, kb, mb, or gb" >&2; exit 1 ;;
  esac
else
  echo "Error: Invalid format. Use: git-large-files [size][unit]" >&2
  echo "Examples: git-large-files 10mb, git-large-files 5gb, git-large-files 100kb" >&2
  exit 1
fi

git rev-list --objects --all |
  git cat-file --batch-check='%(objecttype) %(objectname) %(objectsize) %(rest)' |
  awk -v max="$maxSize" '
    function human(bytes) {
      if (bytes >= 1073741824) return sprintf("%.2f GB", bytes/1073741824)
      if (bytes >= 1048576) return sprintf("%.2f MB", bytes/1048576)
      if (bytes >= 1024) return sprintf("%.2f KB", bytes/1024)
      return sprintf("%d B", bytes)
    }
    $1 == "blob" && $3 > max {
      printf "%10s %s %s\n", human($3), substr($2,1,7), $4
    }
  ' |
  sort -h -r
